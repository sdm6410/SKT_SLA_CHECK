# SK Broadband (T-ID) 계정 정보
SK_ID=your_t_id
SK_PASSWORD=your_password

# Discord Webhook URL (속도 미달/완료 시 알림용, 선택사항)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# 헤드리스 모드 (브라우저 창을 눈에 안보이게 숨길지 여부)
# 초기 테스트 및 확인 시에는 화면을 보면서 진행해야 하므로 false로 둡니다.
HEADLESS=false
